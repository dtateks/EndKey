vietnamese_input_tests.i: vietnamese_input_tests.cpp.i
.PHONY : vietnamese_input_tests.i

# target to preprocess a source file
vietnamese_input_tests.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/EndKeyTests.dir/build.make CMakeFiles/EndKeyTests.dir/vietnamese_input_tests.cpp.i
.PHONY : vietnamese_input_tests.cpp.i

vietnamese_input_tests.s: vietnamese_input_tests.cpp.s
.PHONY : vietnamese_input_tests.s

# target to generate assembly for a file
vietnamese_input_tests.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/EndKeyTests.dir/build.make CMakeFiles/EndKeyTests.dir/vietnamese_input_tests.cpp.s
.PHONY : vietnamese_input_tests.cpp.s

